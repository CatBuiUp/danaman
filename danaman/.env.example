# SMTP (Gmail) — required for contact form emails
# SMTP_USER must match the Gmail account used to create the App Password.
# Do NOT use your normal Gmail password; create an App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-16-char-app-password
